---
const {
  title = 'Sandya Baratha Raj | Research, Publications & Innovation',
  description = 'Professional research timeline for Sandya Baratha Raj, featuring research, patents, media, press releases, posts, and projects.',
  image = '/og-image.jpg'
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sandya Baratha Raj',
  url: 'https://sandy-braj.github.io/',
  image: 'https://sandy-braj.github.io/profile.png',
  sameAs: ['https://www.linkedin.com/in/sbaratharaj/'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Sydney',
    addressRegion: 'NSW',
    addressCountry: 'AU'
  }
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#f5f0e7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#11100e" media="(prefers-color-scheme: dark)" />

    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content="Sandya Baratha Raj" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/profile.png" />
    <link rel="preload" as="image" href="/profile.png" />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const systemDark = matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.dataset.theme = stored || (systemDark ? 'dark' : 'light');
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
